# Production Environment Variables
# IMPORTANT: Set this in Vercel Environment Variables to your Railway backend URL
# Find your Railway backend URL in Railway dashboard (it looks like: https://visibiapp-production-xxxx.up.railway.app)
# Then add VITE_API_URL to Vercel project settings > Environment Variables
VITE_API_URL=https://visibiapp-production.up.railway.app

# Google reCAPTCHA v3 Site Key
# Get your site key from https://www.google.com/recaptcha/admin
# IMPORTANT: Also add this to Vercel Environment Variables
VITE_RECAPTCHA_SITE_KEY=YOUR_RECAPTCHA_SITE_KEY_HERE
